#!/usr/bin/env bash
set -euo pipefail

SSTOR_DIR="$HOME/dev/sessionator"

SERVER_CMD=""
KILL=false
END=false
DELETE=false
LIST=false
MERGE=false
DERGE=false
SYNC=false
TASK=""
BUG=""
APP_KEY=""
CLAIM_NEXT=false
USE_TASK=false
PROJECT=""
INSTANCE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --server=*) SERVER_CMD="${1#--server=}" ;;
    -s|--server) SERVER_CMD="$2"; shift ;;
    --project=*) PROJECT="${1#--project=}" ;;
    -p|--project) PROJECT="$2"; shift ;;
    --instance=*) INSTANCE="${1#--instance=}" ;;
    -i|--instance) INSTANCE="$2"; shift ;;
    -k|--kill) KILL=true ;;
    -e|--end) END=true ;;
    -d|--delete) DELETE=true ;;
    -l|--list) LIST=true ;;
    -m|--merge) MERGE=true ;;
    -g|--derge) DERGE=true ;;
    --sync) SYNC=true ;;
    --task=*) TASK="${1#--task=}" ;;
    --task) TASK="$2"; shift ;;
    --claim-next) CLAIM_NEXT=true ;;
    --bug=*) BUG="${1#--bug=}" ;;
    --bug) BUG="$2"; shift ;;
    --app-key=*) APP_KEY="${1#--app-key=}" ;;
    --app-key) APP_KEY="$2"; shift ;;
    -r|--reload)
      set +u
      source ~/.bash_profile
      set -u
      tmux source-file ~/.tmux.conf 2>/dev/null || true
      echo "Configs reloaded"
      exit 0
      ;;
    -h|--help)
      cat <<'HELP'
sstor — session manager for tmux worktrees and Claude Code

Usage: sstor [options]

Session management:
  -p, --project <name>    Target project (inferred from cwd if omitted)
  -i, --instance <name>   Target instance (worktree)
  -s, --server <cmd>      Start a server window with the given command
                          (auto-read from .sstor/sstor.conf if present)
  -k, --kill              Kill current/target session, switch to next
  -e, --end               Kill current/target session (allows last session)
  -d, --delete            Delete instance: kill session, remove worktree, delete branch
  -l, --list              List all instances for the project
  -m, --merge             Merge instance branch into main project branch
  -g, --derge             Merge, then delete the instance (merge + delete)

Claude agent workflow:
  --task <id>             Create instance for a task, launch orchestrator
  --bug <id>              Create instance for a bug, launch orchestrator
  --claim-next            Create instance, orchestrator claims next Ready task
  --app-key <key>         Set the API key (saved to settings.local.json)

Config:
  --sync                  Re-merge Claude config (.claude/) into project/instance
  -r, --reload            Reload bash profile and tmux config

Environment:
  TASK_APP_KEY            API key for the task/bug sheet web app.
                          Stored in .claude/settings.local.json (never committed).
                          Prompted on first --task/--bug/--claim-next use,
                          or pass --app-key to set it explicitly.
HELP
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
  shift
done

# Infer project from current directory if not specified
if [[ -z "$PROJECT" ]]; then
  CURDIR="$(pwd)"
  if [[ "$CURDIR" == *__worktrees/* ]]; then
    # Inside a worktree: extract project and instance from path
    PROJECT="$(basename "$(dirname "$CURDIR")")"
    PROJECT="${PROJECT%__worktrees}"
    if [[ -z "$INSTANCE" ]]; then
      INSTANCE="$(basename "$CURDIR")"
      INSTANCE="${INSTANCE#"${PROJECT}"-}"
    fi
  else
    PROJECT="$(basename "$CURDIR")"
  fi
fi

REPO_DIR="$HOME/dev/$PROJECT"

if [[ ! -d "$REPO_DIR" ]]; then
  echo "Directory not found: $REPO_DIR"
  exit 1
fi

# --- Merge Claude Code config into a target directory ---
merge_claude_config() {
  local target="$1"
  local source_claude="$SSTOR_DIR/.claude"
  local source_claudemd="$source_claude/CLAUDE.md"
  local url_file="$SSTOR_DIR/planning/deployments/webapp-url"
  local target_claude="$target/.claude"
  local target_claudemd="$target/CLAUDE.md"
  local target_settings="$target_claude/settings.json"

  # 1. Copy agents, commands, memory (overwrite)
  echo "Copying agents, commands, memory..."
  rsync -a \
    --exclude='settings.json' \
    --exclude='settings.local.json' \
    --exclude='CLAUDE.md' \
    "$source_claude/" "$target_claude/"

  # 2. Merge settings.json
  local source_settings="$source_claude/settings.json"
  if [[ ! -f "$source_settings" ]]; then
    echo "No source settings.json, skipping"
  elif [[ ! -f "$target_settings" ]]; then
    echo "Merging settings.json..."
    cp "$source_settings" "$target_settings"
    echo "  Created new settings.json"
  else
    echo "Merging settings.json..."
    python3 -c "
import json

with open('$source_settings') as f:
    src = json.load(f)
with open('$target_settings') as f:
    tgt = json.load(f)

# Merge env (source wins on conflict)
tgt.setdefault('env', {})
for k, v in src.get('env', {}).items():
    tgt['env'][k] = v
    print(f'  Set env: {k}')

# Merge mcpServers (source wins on conflict)
tgt.setdefault('mcpServers', {})
for k, v in src.get('mcpServers', {}).items():
    if k not in tgt['mcpServers']:
        tgt['mcpServers'][k] = v
        print(f'  Added MCP server: {k}')
    else:
        print(f'  Skipped MCP server (already exists): {k}')

# Merge permissions.allow (dedupe)
tgt.setdefault('permissions', {})
tgt_allow = set(tgt['permissions'].get('allow', []))
src_allow = set(src.get('permissions', {}).get('allow', []))
new_perms = src_allow - tgt_allow
if new_perms:
    tgt['permissions']['allow'] = sorted(tgt_allow | src_allow)
    print(f'  Added {len(new_perms)} new permission(s)')
else:
    print('  No new permissions to add')

for key in ['deny', 'defaultMode']:
    if key in src.get('permissions', {}) and key not in tgt['permissions']:
        tgt['permissions'][key] = src['permissions'][key]

if 'sandbox' in src and 'sandbox' not in tgt:
    tgt['sandbox'] = src['sandbox']

with open('$target_settings', 'w') as f:
    json.dump(tgt, f, indent=2)
    f.write('\n')

print('  settings.json merged')
"
  fi

  # 3. Set TASK_APP_URL from last deploy
  if [[ -f "$url_file" ]]; then
    local webapp_url
    webapp_url=$(cat "$url_file")
    echo "Setting TASK_APP_URL..."
    python3 -c "
import json
with open('$target_settings') as f:
    settings = json.load(f)
settings.setdefault('env', {})
settings['env']['TASK_APP_URL'] = '$webapp_url'
with open('$target_settings', 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')
print('  TASK_APP_URL: $webapp_url')
"
  fi

  # 4. Merge CLAUDE.md
  local marker="<!-- implementation-agent-system -->"
  local marker_end="<!-- /implementation-agent-system -->"

  echo "Merging CLAUDE.md..."
  if [[ ! -f "$target_claudemd" ]]; then
    cp "$source_claudemd" "$target_claudemd"
    echo "  Created new CLAUDE.md"
  elif grep -qF "$marker" "$target_claudemd"; then
    python3 -c "
marker = '$marker'
marker_end = '$marker_end'

with open('$target_claudemd') as f:
    content = f.read()
with open('$source_claudemd') as f:
    insert = f.read()

start = content.find(marker)
end = content.find(marker_end)
if start != -1 and end != -1:
    end += len(marker_end)
    content = content[:start] + marker + '\n' + insert + '\n' + marker_end + content[end:]
    print('  Replaced existing implementation agent section')
else:
    content = content[:start] + marker + '\n' + insert + '\n' + marker_end + content[start + len(marker):]
    print('  Rewrapped implementation agent section')

with open('$target_claudemd', 'w') as f:
    f.write(content)
"
  else
    printf '\n%s\n' "$marker" >> "$target_claudemd"
    cat "$source_claudemd" >> "$target_claudemd"
    printf '\n%s\n' "$marker_end" >> "$target_claudemd"
    echo "  Appended implementation agent section"
  fi

  # 5. Merge settings.local.json (contains secrets + task-app permissions, never committed)
  local source_local_settings="$source_claude/settings.local.json"
  local target_local_settings="$target_claude/settings.local.json"
  if [[ -f "$source_local_settings" ]]; then
    echo "Merging settings.local.json..."
    if [[ ! -f "$target_local_settings" ]]; then
      cp "$source_local_settings" "$target_local_settings"
      echo "  Created new settings.local.json"
    else
      python3 -c "
import json

with open('$source_local_settings') as f:
    src = json.load(f)
with open('$target_local_settings') as f:
    tgt = json.load(f)

# Merge env (source wins)
tgt.setdefault('env', {})
for k, v in src.get('env', {}).items():
    tgt['env'][k] = v

# Merge permissions.allow (dedupe)
tgt.setdefault('permissions', {})
tgt_allow = set(tgt['permissions'].get('allow', []))
src_allow = set(src.get('permissions', {}).get('allow', []))
new_perms = src_allow - tgt_allow
if new_perms:
    tgt['permissions']['allow'] = sorted(tgt_allow | src_allow)
    print(f'  Added {len(new_perms)} new permission(s)')

# Merge sandbox.network.allowedDomains (dedupe)
src_sandbox = src.get('sandbox', {})
if src_sandbox:
    tgt.setdefault('sandbox', {})
    tgt['sandbox'].setdefault('network', {})
    src_network = src_sandbox.get('network', {})
    tgt_domains = set(tgt['sandbox']['network'].get('allowedDomains', []))
    src_domains = set(src_network.get('allowedDomains', []))
    new_domains = src_domains - tgt_domains
    if new_domains:
        tgt['sandbox']['network']['allowedDomains'] = sorted(tgt_domains | src_domains)
        print(f'  Added {len(new_domains)} new sandbox domain(s)')
    # Merge other sandbox fields that aren't set
    for k, v in src_sandbox.items():
        if k != 'network' and k not in tgt['sandbox']:
            tgt['sandbox'][k] = v

with open('$target_local_settings', 'w') as f:
    json.dump(tgt, f, indent=2)
    f.write('\n')

print('  settings.local.json merged')
"
    fi
  fi

  # 6. Ensure target .gitignore covers .claude internals and .sstor ephemeral files
  local target_gitignore="$target/.gitignore"
  echo "Checking .gitignore..."
  if [[ ! -f "$target_gitignore" ]]; then
    cat > "$target_gitignore" <<'GI'
### claude ###
.claude/*
!.claude/commands/

### sstor ###
.sstor/.port
GI
    echo "  Created .gitignore with claude/sstor entries"
  else
    local changed=false
    if ! grep -qF '.claude/*' "$target_gitignore"; then
      printf '\n### claude ###\n.claude/*\n' >> "$target_gitignore"
      changed=true
    fi
    if ! grep -qF '!.claude/commands/' "$target_gitignore"; then
      printf '!.claude/commands/\n' >> "$target_gitignore"
      changed=true
    fi
    if ! grep -qF '.sstor/.port' "$target_gitignore"; then
      printf '\n### sstor ###\n.sstor/.port\n' >> "$target_gitignore"
      changed=true
    fi
    if $changed; then
      echo "  Updated .gitignore"
    else
      echo "  .gitignore already up to date"
    fi
  fi

  echo "Done merging Claude config into $target"
}

# Sync Claude config into an existing project/instance
if $SYNC; then
  if [[ -n "$INSTANCE" ]]; then
    SYNC_TARGET="$HOME/dev/${PROJECT}__worktrees/${PROJECT}-${INSTANCE}"
  else
    SYNC_TARGET="$REPO_DIR"
  fi
  if [[ ! -d "$SYNC_TARGET" ]]; then
    echo "Directory not found: $SYNC_TARGET"
    exit 1
  fi
  merge_claude_config "$SYNC_TARGET"
  exit 0
fi

# --task / --bug / --claim-next require TASK_APP_KEY in settings.local.json
LOCAL_SETTINGS="$SSTOR_DIR/.claude/settings.local.json"
if [[ -n "$TASK" ]] || [[ -n "$BUG" ]] || $CLAIM_NEXT; then
  NEED_KEY=false
  if [[ ! -f "$LOCAL_SETTINGS" ]] || ! python3 -c "
import json, sys
with open('$LOCAL_SETTINGS') as f:
    d = json.load(f)
if not d.get('env', {}).get('TASK_APP_KEY'):
    sys.exit(1)
" 2>/dev/null; then
    NEED_KEY=true
  fi
  if $NEED_KEY && [[ -z "${APP_KEY:-}" ]]; then
    echo -n "Enter TASK_APP_KEY: "
    read -r APP_KEY
    if [[ -z "$APP_KEY" ]]; then
      echo "No key provided, aborting."
      exit 1
    fi
  fi
  if [[ -n "${APP_KEY:-}" ]]; then
    mkdir -p "$(dirname "$LOCAL_SETTINGS")"
    if [[ -f "$LOCAL_SETTINGS" ]]; then
      python3 -c "
import json
with open('$LOCAL_SETTINGS') as f:
    d = json.load(f)
d.setdefault('env', {})
d['env']['TASK_APP_KEY'] = '$APP_KEY'
with open('$LOCAL_SETTINGS', 'w') as f:
    json.dump(d, f, indent=2)
    f.write('\n')
"
    else
      python3 -c "
import json
d = {'env': {'TASK_APP_KEY': '$APP_KEY'}}
with open('$LOCAL_SETTINGS', 'w') as f:
    json.dump(d, f, indent=2)
    f.write('\n')
"
    fi
    echo "Saved TASK_APP_KEY to settings.local.json"
  fi
fi

# --task / --bug / --claim-next imply an instance name
if [[ -n "$TASK" ]]; then
  INSTANCE="$TASK"
elif [[ -n "$BUG" ]]; then
  INSTANCE="$BUG"
elif $CLAIM_NEXT; then
  INSTANCE="next-$(date +%Y%m%dT%H%M%S)"
fi

# Kill server process on the port from .sstor/.port and clean up the file
cleanup_server() {
  local dir="$1"
  local port_file="$dir/.sstor/.port"
  if [[ -f "$port_file" ]]; then
    local port
    port=$(cat "$port_file")
    if [[ -n "$port" ]]; then
      local pids
      pids=$(lsof -iTCP:"$port" -sTCP:LISTEN -t 2>/dev/null) || true
      if [[ -n "$pids" ]]; then
        echo "$pids" | xargs kill 2>/dev/null || true
        echo "Killed server on port $port"
      fi
    fi
    rm -f "$port_file"
  fi
}

# Kill session and switch to next available
if $KILL; then
  if [[ -z "${TMUX:-}" ]]; then
    echo "Not inside a tmux session"
    exit 1
  fi
  if [[ -n "$INSTANCE" ]]; then
    TARGET="${PROJECT}-${INSTANCE}"
  else
    TARGET=$(tmux display-message -p '#S')
  fi
  if ! tmux has-session -t "$TARGET" 2>/dev/null; then
    echo "No session: $TARGET"
    exit 1
  fi
  NEXT=$(tmux list-sessions -F '#S' | grep -v "^${TARGET}$" | head -1) || true
  if [[ -z "$NEXT" ]]; then
    echo "Cannot kill the only remaining session"
    exit 1
  fi
  if [[ "$(tmux display-message -p '#S')" == "$TARGET" ]]; then
    tmux switch-client -t "$NEXT"
  fi
  # Resolve dir for cleanup
  if [[ -n "$INSTANCE" ]]; then
    cleanup_server "$HOME/dev/${PROJECT}__worktrees/$TARGET"
  else
    cleanup_server "$REPO_DIR"
  fi
  tmux kill-session -t "$TARGET"
  exit 0
fi

# End session (like kill but allows killing the last session)
if $END; then
  if [[ -z "${TMUX:-}" ]]; then
    echo "Not inside a tmux session"
    exit 1
  fi
  if [[ -n "$INSTANCE" ]]; then
    TARGET="${PROJECT}-${INSTANCE}"
  else
    TARGET=$(tmux display-message -p '#S')
  fi
  if ! tmux has-session -t "$TARGET" 2>/dev/null; then
    echo "No session: $TARGET"
    exit 1
  fi
  NEXT=$(tmux list-sessions -F '#S' | grep -v "^${TARGET}$" | head -1) || true
  if [[ -n "$NEXT" ]] && [[ "$(tmux display-message -p '#S')" == "$TARGET" ]]; then
    tmux switch-client -t "$NEXT"
  fi
  if [[ -n "$INSTANCE" ]]; then
    cleanup_server "$HOME/dev/${PROJECT}__worktrees/$TARGET"
  else
    cleanup_server "$REPO_DIR"
  fi
  tmux kill-session -t "$TARGET"
  exit 0
fi

# List all instances for this project
if $LIST; then
  WORKTREES_DIR="$HOME/dev/${PROJECT}__worktrees"
  if [[ ! -d "$WORKTREES_DIR" ]]; then
    echo "No instances for $PROJECT"
    exit 0
  fi
  for dir in "$WORKTREES_DIR"/"${PROJECT}"-*/; do
    [[ -d "$dir" ]] || continue
    instance="${dir%/}"
    instance="${instance##*/}"
    instance="${instance#"${PROJECT}"-}"
    session="${PROJECT}-${instance}"
    if tmux has-session -t "$session" 2>/dev/null; then
      echo "$instance (active)"
    else
      echo "$instance"
    fi
  done
  exit 0
fi

# Merge instance branch into main project branch and switch to main session
if $MERGE || $DERGE; then
  if [[ -z "$INSTANCE" ]]; then
    echo "Usage: sstor <instance> --merge|--derge"
    exit 1
  fi

  SESSION="${PROJECT}-${INSTANCE}"
  WORKTREE_DIR="$HOME/dev/${PROJECT}__worktrees/$SESSION"
  DEFAULT_BRANCH="$SESSION"

  # Detect the active branch inside the worktree (may be task/<id>-<slug>)
  if [[ -d "$WORKTREE_DIR" ]]; then
    BRANCH=$(git -C "$WORKTREE_DIR" branch --show-current)
  else
    BRANCH="$DEFAULT_BRANCH"
  fi

  if [[ -z "$BRANCH" ]]; then
    echo "Could not determine branch to merge from $WORKTREE_DIR"
    exit 1
  fi

  # Merge into master in the main repo
  CURRENT_BRANCH=$(git -C "$REPO_DIR" branch --show-current)
  if [[ "$CURRENT_BRANCH" != "master" ]]; then
    git -C "$REPO_DIR" checkout master
  fi
  echo "Merging $BRANCH into master..."
  git -C "$REPO_DIR" merge --no-ff "$BRANCH"
  echo "Merged $BRANCH into master"
  if [[ "$CURRENT_BRANCH" != "master" ]]; then
    git -C "$REPO_DIR" checkout "$CURRENT_BRANCH"
  fi

  if $DERGE; then
    # Kill tmux session if it exists
    if tmux has-session -t "$SESSION" 2>/dev/null; then
      if [[ -n "${TMUX:-}" ]] && [[ "$(tmux display-message -p '#S')" == "$SESSION" ]]; then
        # Switch to main project session (create if needed) before killing
        if ! tmux has-session -t "$PROJECT" 2>/dev/null; then
          sstor --project="$PROJECT"
        fi
        tmux switch-client -t "$PROJECT"
      fi
      cleanup_server "$WORKTREE_DIR"
      tmux kill-session -t "$SESSION"
      echo "Killed session: $SESSION"
    fi

    # Remove worktree
    if [[ -d "$WORKTREE_DIR" ]]; then
      git -C "$REPO_DIR" worktree remove --force "$WORKTREE_DIR"
      echo "Removed worktree: $WORKTREE_DIR"
    fi

    # Delete both the task branch (if different) and the worktree default branch
    for b in "$BRANCH" "$DEFAULT_BRANCH"; do
      if [[ -n "$b" ]] && git -C "$REPO_DIR" rev-parse --verify "$b" &>/dev/null; then
        git -C "$REPO_DIR" branch -D "$b"
        echo "Deleted branch: $b"
      fi
    done
  fi

  # Switch to main project session
  if [[ -n "${TMUX:-}" ]]; then
    if ! tmux has-session -t "$PROJECT" 2>/dev/null; then
      sstor --project="$PROJECT"
    fi
    tmux switch-client -t "$PROJECT"
  fi

  exit 0
fi

# Delete an instance: kill session, remove worktree, delete branch
if $DELETE; then
  # Infer instance from current tmux session name if not specified
  if [[ -z "$INSTANCE" ]] && [[ -n "${TMUX:-}" ]]; then
    CURRENT=$(tmux display-message -p '#S')
    if [[ "$CURRENT" == "${PROJECT}"-* ]]; then
      INSTANCE="${CURRENT#"${PROJECT}"-}"
    fi
  fi
  if [[ -z "$INSTANCE" ]]; then
    echo "Usage: sstor -i <instance> --delete"
    exit 1
  fi

  SESSION="${PROJECT}-${INSTANCE}"
  WORKTREE_DIR="$HOME/dev/${PROJECT}__worktrees/$SESSION"

  # Remove worktree first (before killing session, since session may have pwd inside it)
  if [[ -d "$WORKTREE_DIR" ]]; then
    git -C "$REPO_DIR" worktree remove --force "$WORKTREE_DIR"
    echo "Removed worktree: $WORKTREE_DIR"
  fi

  # Delete branch
  if git -C "$REPO_DIR" rev-parse --verify "$SESSION" &>/dev/null; then
    git -C "$REPO_DIR" branch -D "$SESSION"
    echo "Deleted branch: $SESSION"
  fi

  # Kill tmux session if it exists
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    # If we're inside this session, switch away first
    if [[ -n "${TMUX:-}" ]] && [[ "$(tmux display-message -p '#S')" == "$SESSION" ]]; then
      NEXT=$(tmux list-sessions -F '#S' | grep -v "^${SESSION}$" | head -1) || true
      if [[ -z "$NEXT" ]]; then
        echo "Cannot delete the only remaining session"
        exit 1
      fi
      tmux switch-client -t "$NEXT"
    fi
    cleanup_server "$WORKTREE_DIR"
    tmux kill-session -t "$SESSION"
    echo "Killed session: $SESSION"
  fi

  exit 0
fi

# Create/attach session
NEW_SETUP=false
if [[ -n "$INSTANCE" ]]; then
  SESSION="${PROJECT}-${INSTANCE}"
  WORKTREE_DIR="$HOME/dev/${PROJECT}__worktrees/$SESSION"

  if [[ ! -d "$WORKTREE_DIR" ]]; then
    mkdir -p "$HOME/dev/${PROJECT}__worktrees"
    git -C "$REPO_DIR" worktree add "$WORKTREE_DIR" -b "$SESSION"
    NEW_SETUP=true
  fi

  START_DIR="$WORKTREE_DIR"
else
  SESSION="$PROJECT"
  START_DIR="$REPO_DIR"
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    NEW_SETUP=true
  fi
fi

if $NEW_SETUP; then
  merge_claude_config "$START_DIR"
fi

# Read project config from .sstor/sstor.conf (if no --server was passed)
SSTOR_CONF="$REPO_DIR/.sstor/sstor.conf"
if [[ -z "$SERVER_CMD" ]] && [[ -f "$SSTOR_CONF" ]]; then
  _CONF_SERVER_BUILD=""
  _CONF_SERVER_CMD=""
  _CONF_PORT_BASE=""
  while IFS='=' read -r key val; do
    val="${val%\"}" ; val="${val#\"}"  # strip quotes
    case "$key" in
      SERVER_BUILD) _CONF_SERVER_BUILD="$val" ;;
      SERVER_CMD)   _CONF_SERVER_CMD="$val" ;;
      PORT_BASE)    _CONF_PORT_BASE="$val" ;;
    esac
  done < "$SSTOR_CONF"

  if [[ -n "$_CONF_SERVER_CMD" ]]; then
    # Find a free port starting from PORT_BASE
    if [[ -n "$_CONF_PORT_BASE" ]]; then
      PORT="$_CONF_PORT_BASE"
      while lsof -iTCP:"$PORT" -sTCP:LISTEN -t &>/dev/null; do
        PORT=$((PORT + 1))
      done
      echo "Server port: $PORT"
      # Replace {PORT} placeholder in command
      _CONF_SERVER_CMD="${_CONF_SERVER_CMD//\{PORT\}/$PORT}"
      # Write port file so orchestrator/sub-agents can find it
      mkdir -p "$START_DIR/.sstor"
      echo "$PORT" > "$START_DIR/.sstor/.port"
    fi
    if [[ -n "$_CONF_SERVER_BUILD" ]]; then
      SERVER_CMD="$_CONF_SERVER_BUILD && $_CONF_SERVER_CMD"
    else
      SERVER_CMD="$_CONF_SERVER_CMD"
    fi
  fi
fi

# Attach if outside tmux, switch-client if inside tmux.
tmux_go() {
  local session="$1"
  if [[ -n "${TMUX:-}" ]]; then
    exec tmux switch-client -t "$session"
  else
    exec tmux attach -t "$session"
  fi
}

if tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux_go "$SESSION"
fi

WINDOW=1

# Window 1: claude
tmux new-session -d -s "$SESSION" -c "$START_DIR" -n claude
if [[ -n "$TASK" ]]; then
  tmux send-keys -t "$SESSION":$WINDOW "claude '/run-task --task $TASK'" C-m
elif [[ -n "$BUG" ]]; then
  tmux send-keys -t "$SESSION":$WINDOW "claude '/run-task --bug $BUG'" C-m
elif $CLAIM_NEXT; then
  tmux send-keys -t "$SESSION":$WINDOW "claude '/run-task'" C-m
else
  tmux send-keys -t "$SESSION":$WINDOW 'claude --continue' C-m
fi

# Window 2: console
WINDOW=$((WINDOW + 1))
tmux new-window  -t "$SESSION":$WINDOW -n console -c "$START_DIR"

# Window 3: editor
WINDOW=$((WINDOW + 1))
tmux new-window  -t "$SESSION":$WINDOW -n editor -c "$START_DIR"
tmux send-keys   -t "$SESSION":$WINDOW "nvim -c 'Git | only'" C-m

# Window 4: server (optional)
if [[ -n "$SERVER_CMD" ]]; then
  WINDOW=$((WINDOW + 1))
  tmux new-window  -t "$SESSION":$WINDOW -n server -c "$START_DIR"
  tmux send-keys   -t "$SESSION":$WINDOW "$SERVER_CMD" C-m
fi

tmux select-window -t "$SESSION":1
tmux_go "$SESSION"
